# 이 파일을 복사해 application-secret.yml 로 저장하세요 (git 제외됨)
spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/jigeumchamyeo
    username: postgres
    password: your_password_here

# 공공데이터 API 키 (data.go.kr 또는 open.assembly.go.kr 에서 발급)
public-data:
  bill-api-key: YOUR_BILL_API_KEY
  petition-api-key: YOUR_PETITION_API_KEY
  legislation-api-key: YOUR_LEGISLATION_API_KEY
  page-size: 100

# Firebase FCM
firebase:
  credentials-path: classpath:firebase-credentials.json
